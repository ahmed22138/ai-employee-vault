# AI Employee Configuration File
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to git!

# ============================================================================
# ESSENTIAL CONFIGURATION (Required for basic functionality)
# ============================================================================

# ---------- Gmail API (Required for Silver Tier) ----------
# Get from: https://console.cloud.google.com
# 1. Create project
# 2. Enable Gmail API
# 3. Download credentials.json and place in vault root
# Note: token.json will be auto-generated on first run
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# ---------- SMTP Email Sending (Required for Silver Tier) ----------
# Get Gmail App Password from: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-digit-app-password

# ============================================================================
# GOLD TIER CONFIGURATION (Optional - for advanced features)
# ============================================================================

# ---------- WhatsApp (Optional - Gold Tier) ----------
# Session will be saved after first QR scan
WHATSAPP_SESSION_PATH=~/.whatsapp_session
WHATSAPP_CHECK_INTERVAL=30
WHATSAPP_HEADLESS=false
# ---------- Odoo Accounting (Optional - Gold Tier) ----------
# Only needed if you have Odoo instance
ODOO_URL=https://your-company.odoo.com
ODOO_DB=your-database-name
ODOO_USERNAME=your-email@company.com
ODOO_PASSWORD=your-odoo-password

# ---------- Facebook (Optional - Gold Tier) ----------
# Get from: https://developers.facebook.com
# 1. Create app
# 2. Get Page Access Token from Graph API Explorer
# 3. Permissions needed: pages_manage_posts
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-token
FACEBOOK_PAGE_ID=your-facebook-page-id

# ---------- Instagram (Optional - Gold Tier) ----------
# Requires Instagram Business Account linked to Facebook Page
# Get account ID from Graph API Explorer: /me/accounts
INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id

# ---------- Twitter/X (Optional - Gold Tier) ----------
# Get from: https://developer.twitter.com
# 1. Create app
# 2. Generate API keys and access tokens
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# ---------- LinkedIn (Silver Tier) ----------
# Used for automated LinkedIn posting via browser automation
# Your LinkedIn account credentials
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# ---------- General Settings ----------
VAULT_PATH=/mnt/e/all-d-files/Ai_Employee_Vault
DRY_RUN=false
LOG_LEVEL=INFO

# ---------- Browser Automation ----------
# Set to true for headless mode (no visible browser window)
# Set to false to see browser window (useful for debugging)
BROWSER_HEADLESS=true

# ---------- Watcher Intervals (in seconds) ----------
FILESYSTEM_WATCH_INTERVAL=5
GMAIL_CHECK_INTERVAL=120
WHATSAPP_CHECK_INTERVAL=30
ORCHESTRATOR_CHECK_INTERVAL=120

# ---------- Error Recovery ----------
ERROR_RECOVERY_CHECK_INTERVAL=60
MAX_RETRIES=3
BACKOFF_BASE=2
MAX_BACKOFF=300

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================

# Set to true for testing without actual API calls
# Useful when you don't have credentials yet
# DRY_RUN=true

# Set to DEBUG for more detailed logs
# LOG_LEVEL=DEBUG
